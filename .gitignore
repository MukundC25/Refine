# ── Node.js ───────────────────────────────────────────────────────────────── #
node_modules/
dist/
build/

# ── Python ────────────────────────────────────────────────────────────────── #
venv/
.venv/
.venv312/
__pycache__/
*.py[cod]
*.pyo

# ── Environment & secrets ─────────────────────────────────────────────────── #
.env
.env.*
!.env.production       # keep committed (no secrets, only public URLs)
!.env.example          # keep committed (documents all variables, no real values)

# ── OS artefacts ──────────────────────────────────────────────────────────── #
.DS_Store
Thumbs.db

# ── Database ──────────────────────────────────────────────────────────────── #
*.db

# ── Ranking system — large data files (Issue 001) ─────────────────────────── #
submission.csv
candidates.jsonl
candidates.jsonl.gz
*.embeddings.npy
# Allow parsed JD cache and rich reasoning (small JSON — no secrets, needed for judges)
precomputed/*.npy
precomputed/*.json.gz
precomputed/*.bin

# ── Logs (Issue 017) ──────────────────────────────────────────────────────── #
logs/

# ── Jupyter ───────────────────────────────────────────────────────────────── #
notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/

# ── Docs (generated / challenge-internal) ─────────────────────────────────── #
docs/
